{
  "name": "@runilib/react-walkit",
  "version": "1.0.0",
  "description": "Cross-platform tooltip, onboarding tours, product walkthroughs and contextual help for React and React Native. One API. Declarative. Animated. Accessible.",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "react-native": "./dist/index.native.mjs",
  "exports": {
    ".": {
      "react-native": {
        "types": "./dist/index.native.d.mts",
        "default": "./dist/index.native.mjs"
      },
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "dev": "tsup --watch --config tsup.config.ts",
    "build": "rimraf dist && tsup --config tsup.config.ts",
    "lint": "biome lint src .",
    "lint:fix": "biome lint --write src .",
    "check": "biome check src .",
    "check:fix": "biome check --write src .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "tsc:build": "tsc -b tsconfig-build.json",
    "tsc:check": "tsc --noEmit",
    "tsc:watch": "tsc --noEmit --watch",
    "prepack": "node ../../scripts/package-pack-sourcemaps.mjs hide",
    "postpack": "node ../../scripts/package-pack-sourcemaps.mjs restore",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "react",
    "react-native",
    "onboarding",
    "user-onboarding",
    "tour",
    "app-tour",
    "guided-tour",
    "product-tour",
    "guide",
    "stepwise",
    "step",
    "tooltip",
    "spotlight",
    "feature-discovery",
    "contextual-help",
    "react-walkit",
    "walkthrough",
    "product-walkthrough",
    "tutorial",
    "universal",
    "cross-platform",
    "cross-page-tour",
    "cross-screen-tour",
    "multi-page-tour",
    "react-router",
    "expo-router",
    "react-navigation",
    "react-navigation-native",
    "typescript",
    "intro.js",
    "intro"
  ],
  "author": "AKS <akladekouassi@gmail.com>",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "react-native": ">=0.60.0",
    "react-native-svg": ">=15.12.1"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    },
    "react-test-renderer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "@babel/preset-typescript": "^7.23.0",
    "@biomejs/biome": "^2.4.8",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react": "16.3.2",
    "@testing-library/react-native": "^12.4.3",
    "@tsconfig/react-native": "^3.0.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^18.0.0",
    "@types/react-test-renderer": "^18.0.7",
    "@vitest/coverage-v8": "^4.1.1",
    "jest-environment-jsdom": "^29.7.0",
    "react": "18.3.1",
    "react-dom": "^18.0.0",
    "react-native": "^0.84.1",
    "react-native-svg": "^15.15.4",
    "react-test-renderer": "^18.2.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "vitest": "^4.1.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/runilib/react-walkit.git"
  },
  "bugs": {
    "url": "https://github.com/runilib/react-walkit/issues"
  },
  "homepage": "https://github.com/runilib/react-walkit#readme",
  "sideEffects": false
}
