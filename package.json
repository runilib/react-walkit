{
  "name": "@runilib/react-walkit",
  "version": "1.0.0",
  "description": "Cross-platform onboarding / guided tour for React and React Native — same API on both.",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "react-native": "./dist/index.native.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "react-native": "./dist/index.native.mjs",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "dev": "tsup --watch --config tsup.config.ts",
    "build": "tsup --config tsup.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "biome ci src",
    "lint:fix": "biome check --write src",
    "tsc:build": "tsc -b tsconfig-build.json",
    "tsc:check": "tsc --noEmit",
    "tsc:watch": "tsc --noEmit --watch",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "react",
    "react-native",
    "onboarding",
    "tour",
    "guide",
    "stepwise",
    "step",
    "tooltip",
    "react-walkit",
    "walkthrough",
    "tutorial",
    "universal",
    "cross-platform",
    "typescript",
    "intro.js",
    "intro"
  ],
  "author": "GoNextStep <tech-founder@gonextstep.io>",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "react-native": ">=0.60.0",
    "react-native-svg": "15.12.1"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    },
    "react-test-renderer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "@babel/preset-typescript": "^7.23.0",
    "@biomejs/biome": "2.3.9",
    "@runilib/biome-config": "workspace:*",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react": "^14.0.0",
    "@testing-library/react-native": "^12.4.3",
    "@tsconfig/react-native": "^3.0.3",
    "@types/jest": "^29.5.12",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^18.0.0",
    "@types/react-test-renderer": "^18.0.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react-dom": "^18.0.0",
    "react-native": "^0.84.1",
    "react-native-svg": "^15.15.4",
    "react-test-renderer": "^18.2.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.1.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/runilib/react-walkit.git"
  },
  "bugs": {
    "url": "https://github.com/runilib/react-walkit/issues"
  },
  "homepage": "https://github.com/runilib/react-walkit#readme",
  "sideEffects": false
}
